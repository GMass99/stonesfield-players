---
layout: layouts/base.njk
currentPage: contact
pageTitle: "Contact — Stonesfield Players"
metaDescription: "Get in touch with the Stonesfield Players. Join our drama group or find out about upcoming shows."
permalink: /contact/
---

<!-- PAGE HEADER -->
<section class="page-header">
  <div class="container">
    <p class="section-subtitle">{{ contact.page_header.subtitle }}</p>
    <h1>{{ contact.page_header.title }}</h1>
    <p>{{ contact.page_header.description }}</p>
  </div>
</section>

<!-- CONTACT CONTENT -->
<section>
  <div class="container">
    <div class="contact-grid">

      <!-- Contact Info -->
      <div class="contact-info">
        <h3>Contact Details</h3>

        <div class="contact-item">
          <div class="icon">&#9993;</div>
          <div>
            <h4>Email</h4>
            <a href="mailto:{{ site.email }}">{{ site.email }}</a>
          </div>
        </div>

        <div class="contact-item">
          <div class="icon">&#128205;</div>
          <div>
            <h4>Venue</h4>
            <p>{{ site.venue.name }}<br>{{ site.venue.address }}<br>{{ site.venue.postcode }}</p>
          </div>
        </div>

        <div class="contact-item">
          <div class="icon">&#128247;</div>
          <div>
            <h4>Instagram</h4>
            <a href="{{ site.instagram_url }}" target="_blank" rel="noopener">{{ site.instagram_handle }}</a>
          </div>
        </div>

        <div style="margin-top:2rem;padding:2rem;background:var(--off-white);">
          <h4 style="font-family:var(--font-heading);font-size:1.1rem;margin-bottom:0.75rem;">{{ contact.join_box.heading }}</h4>
          <p style="color:var(--grey-dark);font-size:0.9rem;margin-bottom:0;">{{ contact.join_box.text | safe }}</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form">
        <h3>Send Us a Message</h3>
        <form action="#" method="POST">
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" placeholder="Jane Smith" required>
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="jane@example.com" required>
          </div>
          <div class="form-group">
            <label for="subject">I'm Interested In</label>
            <select id="subject" name="subject">
              <option value="general">General Enquiry</option>
              <option value="joining">Joining the Group</option>
              <option value="tickets">Ticket Information</option>
              <option value="press">Press / Media</option>
              <option value="other">Something Else</option>
            </select>
          </div>
          <div class="form-group">
            <label for="message">Your Message</label>
            <textarea id="message" name="message" placeholder="Tell us what's on your mind..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- MAP -->
<section class="map-section">
  <div>
    {% if contact.map_embed_url %}
      <iframe src="{{ contact.map_embed_url }}" width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
    {% else %}
      <p>&#128205; Map of Stonesfield Village Hall</p>
      <p style="font-size:0.8rem;margin-top:0.5rem;">Embed a Google Map here, or replace with a static image.</p>
    {% endif %}
  </div>
</section>
