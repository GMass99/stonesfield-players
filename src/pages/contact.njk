---
layout: layouts/base.njk
currentPage: contact
pageTitle: "Contact — Stonesfield Players"
metaDescription: "Get in touch with the Stonesfield Players. Join our drama group or find out about upcoming shows."
permalink: /contact/
---

<!-- PAGE HEADER -->
<section class="page-header">
  <div class="container">
    <p class="section-subtitle">{{ contact.page_header.subtitle }}</p>
    <h1>{{ contact.page_header.title }}</h1>
    <p>{{ contact.page_header.description }}</p>
  </div>
</section>

<!-- CONTACT CONTENT -->
<section>
  <div class="container">
    <div class="contact-grid">

      <!-- Contact Info -->
      <div class="contact-info">
        <h3>Contact Details</h3>

        <div class="contact-item">
          <div class="icon">&#9993;</div>
          <div>
            <h4>Email</h4>
            <a href="mailto:{{ contact.email }}">{{ contact.email }}</a>
          </div>
        </div>

        <div class="contact-item">
          <div class="icon">&#128205;</div>
          <div>
            <h4>Venue</h4>
            <p>{{ contact.venue.name }}<br>{{ contact.venue.address }}<br>{{ contact.venue.postcode }}</p>
          </div>
        </div>

        {% for social in site.social_links %}
        <div class="contact-item">
          <div class="icon">{{ social.icon }}</div>
          <div>
            <h4>{{ social.platform }}</h4>
            <a href="{{ social.url }}" target="_blank" rel="noopener">{{ social.handle }}</a>
          </div>
        </div>
        {% endfor %}

        <div style="margin-top:2rem;padding:2rem;background:var(--off-white);">
          <h4 style="font-family:var(--font-heading);font-size:1.1rem;margin-bottom:0.75rem;">{{ contact.join_box.heading }}</h4>
          <p style="color:var(--grey-dark);font-size:0.9rem;margin-bottom:0;">{{ contact.join_box.text | safe }}</p>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form">
        <h3>Send Us a Message</h3>
        <form action="#" method="POST">
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" placeholder="Jane Smith" required>
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="jane@example.com" required>
          </div>
          <div class="form-group">
            <label for="subject">I'm Interested In</label>
            <select id="subject" name="subject">
              {% for subject in contact.form_subjects %}
                <option value="{{ subject | lower | replace(' ', '_') }}">{{ subject }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="form-group">
            <label for="message">Your Message</label>
            <textarea id="message" name="message" placeholder="Tell us what's on your mind..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>

    </div>
  </div>
</section>

<!-- PHOTO GALLERY -->
<section style="background:var(--off-white);">
  <div class="container" style="text-align:center;">
    <h2>{{ contact.gallery.heading }}</h2>
    {% if contact.gallery.photos.length %}
    <div class="gallery-grid">
      {% for photo in contact.gallery.photos %}
      <div class="gallery-item">
        <img src="{{ photo.image }}" alt="{{ photo.caption }}" loading="lazy">
        {% if photo.caption %}
          <p class="gallery-caption">{{ photo.caption }}</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% else %}
    <p style="color:var(--grey-mid);margin-top:1.5rem;">Photos coming soon — check back after our next production!</p>
    {% endif %}
  </div>
</section>
